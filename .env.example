POSTGRES_DB=proxymesh
POSTGRES_USER=proxymesh
POSTGRES_PASSWORD=local-only-password
DATABASE_URL=postgres://proxymesh:local-only-password@postgres:5432/proxymesh?sslmode=disable
ENCRYPTION_KEY=replace-with-a-random-32-byte-base64-value
ADMIN_TOKEN=replace-with-a-long-random-token
PUBLIC_PROXY_HOST=proxy.example.com
